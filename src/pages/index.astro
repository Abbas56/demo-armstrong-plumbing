---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/TrustBar.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import FAQ from '../components/FAQ.astro';
import CTABand from '../components/CTABand.astro';
import { site } from '../data/site';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Armstrong Plumbing & Heating Ltd",
  "description": "Gas Safe registered plumbers in Leeds for boilers, bathrooms, emergencies and landlord gas safety certificates.",
  "telephone": "+441134967821",
  "email": "hello@armstrongplumbing-demo.co.uk",
  "url": "https://example.com/",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "14 Kirkstall Road",
    "addressLocality": "Leeds",
    "addressRegion": "West Yorkshire",
    "postalCode": "LS5 3BL",
    "addressCountry": "GB"
  },
  "areaServed": "West Yorkshire"
};

const previewFaqs = [{"question":"Do you charge a call-out fee?","answer":"We do not charge for quotes within LS postcodes. Emergency out-of-hours visits may include a call-out fee—we tell you before we dispatch."},{"question":"Are you Gas Safe registered?","answer":"Yes. Our registration number is 612847 (demo). You can verify this on the Gas Safe Register website."},{"question":"How quickly can you fit a new boiler?","answer":"Most replacements are completed in 1–2 days once parts are confirmed. We often have same-week survey slots."}];

const services = [
  { title: "Boiler installation", description: "Worcester, Vaillant and Ideal systems with warranty registration.", href: "/services/boiler-installation/" },
  { title: "Boiler repair & servicing", description: "Breakdown repairs and annual services to keep warranties valid.", href: "/services/boiler-repair-servicing/" },
  { title: "Emergency plumbing", description: "Burst pipes, leaks and loss of heating—prioritised response.", href: "/services/emergency-plumbing/" },
  { title: "Bathroom plumbing", description: "First and second-fix plumbing for refurbishments.", href: "/services/bathroom-plumbing/" },
  { title: "Landlord CP12", description: "Annual gas safety certificates with reminder scheduling.", href: "/services/landlord-gas-safety/" },
  { title: "Heating & radiators", description: "Power flushing, TRVs and smart thermostat installs.", href: "/services/central-heating-radiators/" },
];
---
<BaseLayout title={`${site.name} — ${site.tagline}`} description={site.description} jsonLd={jsonLd}>
  <TrustBar />
  <section class="hero-split">
    <div class="wrap hero-split__grid">
      <div>
        <h1>Plumbing &amp; heating engineers you can actually rely on in Leeds</h1>
        <p class="lead">Gas Safe registered. Fixed quotes on boiler installs. Same-week appointments across Leeds and West Yorkshire.</p>
        <a class="hero-split__phone" href={`tel:${site.phoneTel}`}>{site.phone}</a>
        <div class="hero-split__actions">
          <a class="btn btn--orange" href={site.primaryCtaHref}>{site.primaryCtaLabel}</a>
          <a class="btn btn--navy" href="/services/emergency-plumbing/">Emergency</a>
        </div>
      </div>
      <div class="hero-split__photo" role="img" aria-label="Engineer at work placeholder"></div>
    </div>
  </section>
  <section class="block block--dense">
    <div class="wrap">
      <h2>Our services</h2>
      <ServiceGrid services={services} />
    </div>
  </section>
  <section class="block block--white">
    <div class="wrap">
      <h2>Why Armstrong</h2>
      <ol class="why-list">
        <li><strong>Gas Safe registered</strong> — every gas job completed by certified engineers, with paperwork for landlords.</li>
        <li><strong>Fixed written quotes</strong> — no surprise extras on boiler installs once we have surveyed your home.</li>
        <li><strong>Local Leeds team</strong> — based on Kirkstall Road, covering LS postcodes and wider West Yorkshire.</li>
      </ol>
    </div>
  </section>
  <section class="block">
    <div class="wrap">
      <h2>What customers say</h2>
      <div class="review-quotes" style="margin-top:1rem">
        <blockquote class="review-quote">
          <div class="review-quote__stars" aria-label="5 stars">★★★★★</div>
          <p>Fair price and left the kitchen spotless.</p>
          <cite>Janet M., Roundhay</cite>
        </blockquote>
        <blockquote class="review-quote">
          <div class="review-quote__stars" aria-label="5 stars">★★★★★</div>
          <p>Quote matched the final invoice.</p>
          <cite>Paul R., Kirkstall</cite>
        </blockquote>
      </div>
      <p style="margin-top:1rem"><a href="/reviews/">Read all reviews →</a></p>
    </div>
  </section>
  <section class="block block--white">
    <div class="wrap">
      <h2>Areas we cover</h2>
      <div class="area-pills">
        <a class="area-pill" href="/areas/leeds/">Leeds</a>
        <a class="area-pill" href="/areas/bradford/">Bradford</a>
        <a class="area-pill" href="/areas/wakefield/">Wakefield</a>
      </div>
      <div class="map-placeholder" role="img" aria-label="Service area map placeholder">Leeds &amp; West Yorkshire — map placeholder</div>
    </div>
  </section>
  <FAQ items={previewFaqs} title="Common questions" />
  <CTABand heading="Need a plumber or heating engineer this week?" text="Tell us what is wrong—we will call you back within one working hour." />
</BaseLayout>
