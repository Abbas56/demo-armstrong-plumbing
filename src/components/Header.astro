---
import { site } from '../data/site';
import { withBase } from '../utils/withBase';
---
<header class="arm-header">
  <div class="wrap arm-header__row">
    <a class="arm-header__brand" href={withBase('/')}>{site.name}</a>
    <a class="arm-header__phone" href={`tel:${site.phoneTel}`}>{site.phone}</a>
    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" id="nav-toggle">
      <span></span><span></span><span></span>
      <span class="visually-hidden">Menu</span>
    </button>
    <nav class="arm-nav" aria-label="Main">
      {site.nav.map((item) => (
        <a href={withBase(item.href)}>{item.label}</a>
      ))}
    </nav>
  </div>
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile" hidden>
    {site.nav.map((item) => (
      <a href={withBase(item.href)}>{item.label}</a>
    ))}
  </nav>
</header>
<style>.visually-hidden{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0}</style>
<script>
  const btn = document.getElementById('nav-toggle');
  const nav = document.getElementById('mobile-nav');
  if (btn && nav) {
    btn.addEventListener('click', () => {
      const open = nav.classList.toggle('is-open');
      nav.hidden = !open;
      btn.setAttribute('aria-expanded', String(open));
    });
  }
</script>
